# ──────────────────────────────────────────────────────
#  PixelVault — Environment Variables
#  Copy this file to .env and fill in your values.
#  NEVER commit .env to version control.
# ──────────────────────────────────────────────────────

# Absolute path to your media folder on the host machine
MEDIA_PATH=/path/to/your/media

# TMDB API Read Access Token (v4 bearer)
# Get one free at: https://www.themoviedb.org/settings/api
TMDB_TOKEN=

# Optional: self-hosted WebRTC signaling server URL
# Leave empty to use the public Cloudflare Worker fallback
# SIGNAL_URL=http://YOUR_PUBLIC_IP:4747

# ── Production overrides (docker-compose.prod.yml) ────
# JWT_SECRET=change_this_to_a_long_random_secret_in_production
# DB_PASSWORD=change_this_in_production
